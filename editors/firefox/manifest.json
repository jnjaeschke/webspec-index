{
  "manifest_version": 2,
  "name": "webspec-lens",
  "version": "0.9.0",
  "description": "Show web spec content inline on Phabricator and Searchfox",
  "permissions": [
    "nativeMessaging"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://phabricator.services.mozilla.com/*",
        "https://searchfox.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "webspec-lens@mozilla.org",
      "strict_min_version": "109.0"
    }
  }
}
